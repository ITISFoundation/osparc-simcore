{% extends 'email/_base/body_html.j2' %}
{% block title %} {% include 'email/share_project/subject.j2' %} {% endblock %}
{% block content %}
<p>Dear {{ user.first_name or user.user_name }},</p>

<p>Great news! {{ sharer.user_name }} has shared a project with you on {{ product.display_name }}.</p>

<p>To view the project and accept the sharing, follow below:</p>

{% if sharer.message %}
<div style="border: 1px solid #ccc; padding: 16px; border-radius: 8px; background-color: #f9f9f9; margin-top: 20px; margin-bottom: 20px;">
  <p style="margin-top: 0;">{{ sharer.message }}</p>
  <!-- Bulletproof button: table-based for maximum email client compatibility -->
  <table border="0" cellpadding="0" cellspacing="0" role="presentation">
    <tr>
      <td style="{{ strong_button_td_style }}">
        <a href="{{ accept_link }}" target="_blank" rel="noopener noreferrer" style="{{ strong_button_link_style }}">
          Open
        </a>
      </td>
    </tr>
  </table>
</div>
{% else %}
<!-- Bulletproof button: table-based for maximum email client compatibility -->
<table border="0" cellpadding="0" cellspacing="0" role="presentation" style="margin-top: 10px; margin-bottom: 10px;">
  <tr>
    <td style="{{ strong_button_td_style }}">
      <a href="{{ accept_link }}" target="_blank" rel="noopener noreferrer" style="{{ strong_button_link_style }}">
        Open
      </a>
    </td>
  </tr>
</table>
{% endif %}

<p>Please don't hesitate to contact us at {{ product.support_email }} if you need further help.</p>

<p>Best Regards,</p>
<p>The <i>{{ product.display_name }}</i> Team</p>
{% endblock %}
