{% extends 'email/_base/body_html.j2' %}
{% block title %} {% include 'email/registered/subject.j2' %} {% endblock %}
{% block content %}
<p>{% trans first_name=user.first_name or user.user_name %}Dear {{ first_name }},{% endtrans %}</p>
<p>{% trans product_name=product.display_name, host=host %}Thank you for your interest in {{ product_name }}. You have successfully registered for {{ host }}.{% endtrans %}</p>
<p>{% trans %}Please activate your account via the link below:{% endtrans %}</p>
<!-- Bulletproof button: table-based for maximum email client compatibility -->
<table border="0" cellpadding="0" cellspacing="0" role="presentation" style="margin-top: 10px; margin-bottom: 10px;">
  <tr>
    <td style="{{ strong_button_td_style }}">
      <a href="{{ link }}" target="_blank" rel="noopener noreferrer" style="{{ strong_button_link_style }}">
        {% trans %}Activate{% endtrans %}
      </a>
    </td>
  </tr>
</table>
{% set support_link %}<a href="mailto:{{ product.support_email }}">{{ product.support_email }}</a>{% endset %}
<p>{% trans support_link=support_link %}Please don't hesitate to contact us at {{ support_link }} if you need further help.{% endtrans %}</p>
<p>{% trans %}Best Regards,{% endtrans %}</p>
{% set product_name %}<i>{{ product.display_name }}</i>{% endset %}
<p>{% trans product_name=product_name %}The {{ product_name }} Team{% endtrans %}</p>
{% endblock %}
