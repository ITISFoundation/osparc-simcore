{% extends 'email/_base/body_html.j2' %}
{% block title %} {% include 'email/share_project/subject.j2' %} {% endblock %}
{% block content %}
<p>{% trans first_name=user.first_name or user.user_name %}Dear {{ first_name }},{% endtrans %}</p>

<p>{% trans sharer_name=sharer.user_name, product_name=product.display_name %}Great news! {{ sharer_name }} has shared a project with you on {{ product_name }}.{% endtrans %}</p>

<p>{% trans %}To view the project and accept the sharing, follow below:{% endtrans %}</p>

{% if sharer.message %}
<div style="border: 1px solid #ccc; padding: 16px; border-radius: 8px; background-color: #f9f9f9; margin-top: 20px; margin-bottom: 20px;">
  <p style="margin-top: 0;">{{ sharer.message }}</p>
  <!-- Bulletproof button: table-based for maximum email client compatibility -->
  <table border="0" cellpadding="0" cellspacing="0" role="presentation">
    <tr>
      <td style="{{ strong_button_td_style }}">
        <a href="{{ accept_link }}" target="_blank" rel="noopener noreferrer" style="{{ strong_button_link_style }}">
          {% trans %}Open{% endtrans %}
        </a>
      </td>
    </tr>
  </table>
</div>
{% else %}
<!-- Bulletproof button: table-based for maximum email client compatibility -->
<table border="0" cellpadding="0" cellspacing="0" role="presentation" style="margin-top: 10px; margin-bottom: 10px;">
  <tr>
    <td style="{{ strong_button_td_style }}">
      <a href="{{ accept_link }}" target="_blank" rel="noopener noreferrer" style="{{ strong_button_link_style }}">
        {% trans %}Open{% endtrans %}
      </a>
    </td>
  </tr>
</table>
{% endif %}

{% set support_link %}<a href="mailto:{{ product.support_email }}">{{ product.support_email }}</a>{% endset %}
<p>{% trans support_link=support_link %}Please don't hesitate to contact us at {{ support_link }} if you need further help.{% endtrans %}</p>

<p>{% trans %}Best Regards,{% endtrans %}</p>
{% set product_name %}<i>{{ product.display_name }}</i>{% endset %}
<p>{% trans product_name=product_name %}The {{ product_name }} Team{% endtrans %}</p>
{% endblock %}
