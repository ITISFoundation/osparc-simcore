      },
      "Envelope_list_dict_str__Any___": {
        "properties": {
          "data": {
            "anyOf": [
              {
                "items": {
                  "additionalProperties": true,
                  "type": "object"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Data"
          },
          "error": {
            "anyOf": [
              {},
              {
                "type": "null"
              }
            ],
            "title": "Error"
          }
        },
        "type": "object",
        "title": "Envelope[list[dict[str, Any]]]"
      },
      "HTTPValidationError": {
        "properties": {
          "errors": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Validation errors"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ServiceType": {
        "type": "string",
        "enum": [
          "computational",
          "dynamic",
          "frontend",
          "backend"
        ],
        "title": "ServiceType"
      },
      "ValidationError": {
        "properties": {
