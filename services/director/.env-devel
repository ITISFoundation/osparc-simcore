#
# The following environment variables are used to configure this service
#
# - These variables are parsed and validated in core/settings.py
#

# -- Director --
LOG_LEVEL=WARNING
LOG_FORMAT_LOCAL_DEV_ENABLED=false
DIRECTOR_REGISTRY_CACHING=true
DIRECTOR_REGISTRY_CACHING_TTL=PT15M
DIRECTOR_GENERIC_RESOURCE_PLACEMENT_CONSTRAINTS_SUBSTITUTIONS='{}'
TRAEFIK_SIMCORE_ZONE=internal_simcore_stack
STORAGE_ENDPOINT=storage:8080
PUBLISHED_HOST_NAME=127.0.0.1
SWARM_STACK_NAME=simcore
SIMCORE_SERVICES_NETWORK_NAME=null
MONITORING_ENABLED=false

# -- Registry (RegistrySettings) --
REGISTRY_AUTH=true
REGISTRY_URL=registry:5000
REGISTRY_USER=admin
REGISTRY_PW=adminadmin
REGISTRY_SSL=false

# -- Postgres (PostgresSettings) --
POSTGRES_HOST=localhost
POSTGRES_USER=scu
POSTGRES_PASSWORD=adminadmin
POSTGRES_DB=simcoredb
